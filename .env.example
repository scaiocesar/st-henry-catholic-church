# Database
# Option 1: Transaction mode (6543) - recommended for production with Supabase free tier
# Use pgbouncer mode to avoid prepared statement conflicts
DATABASE_URL="postgresql://user:password@host.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"

# Option 2: Direct connection (5432) - may work better for local builds
# DATABASE_URL="postgresql://user:password@host.supabase.co:5432/postgres"

# Session
SESSION_SECRET="your-session-secret-here"

# Admin
ADMIN_PASSWORD="your-admin-password"

# S3 Storage (Supabase Storage via S3 API)
S3_URL="https://xxxxx.storage.supabase.co/storage/v1/s3"
S3_PROJECT_REF="xxxxx"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET="uploads"
