generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MassSchedule {
  id          Int      @id @default(autoincrement())
  day         String   @db.VarChar(50)
  time        String   @db.VarChar(50)
  language    String   @db.VarChar(50)
  locationId  Int?
  location    Location? @relation(fields: [locationId], references: [id])
  massType    String   @default("mass") @db.VarChar(50)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([locationId])
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  address     String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  schedules   MassSchedule[]

  @@index([isActive, sortOrder])
}

model SpecialMass {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  description String?  @db.Text
  date        DateTime
  time        String   @db.VarChar(50)
  location    String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, date])
}

model GalleryPhoto {
  id          Int      @id @default(autoincrement())
  title       String?  @db.VarChar(200)
  url         String   @db.VarChar(500)
  s3Key       String?  @db.VarChar(500)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Bulletin {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(200)
  url         String   @db.VarChar(500)
  s3Key       String?  @db.VarChar(500)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isCurrent   Boolean  @default(false)
  publishDate DateTime @default(now())
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, isCurrent, publishDate])
}

model SocialLink {
  id          Int      @id @default(autoincrement())
  platform    String   @db.VarChar(50)
  url         String   @db.VarChar(500)
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model SiteSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id        Int      @id @default(autoincrement())
  category  String   @db.VarChar(100)
  title     String?  @db.VarChar(500)
  content   String   @db.Text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category])
  @@index([isActive, sortOrder])
}

model HomeContent {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AboutContent {
  id        Int      @id @default(autoincrement())
  section   String   @db.VarChar(100)
  title     String?  @db.VarChar(500)
  content   String   @db.Text
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  createdAt DateTime @default(now())
}
